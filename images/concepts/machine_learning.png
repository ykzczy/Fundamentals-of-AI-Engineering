<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 350">
  <!-- Background -->
  <rect width="500" height="350" fill="#f8f9fa"/>
  
  <!-- Title -->
  <text x="250" y="30" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle" fill="#2c3e50">Machine Learning Concept</text>
  
  <!-- Data Input -->
  <rect x="30" y="100" width="100" height="80" rx="10" fill="#3498db"/>
  <text x="80" y="135" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="white">Training</text>
  <text x="80" y="155" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="white">Data</text>
  
  <!-- Arrow to Model -->
  <line x1="130" y1="140" x2="180" y2="140" stroke="#7f8c8d" stroke-width="3" marker-end="url(#arrow)"/>
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#7f8c8d"/>
    </marker>
  </defs>
  
  <!-- Model/Algorithm -->
  <rect x="190" y="90" width="120" height="100" rx="10" fill="#9b59b6"/>
  <text x="250" y="125" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="white">ML Model</text>
  <text x="250" y="145" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">(Training)</text>
  <text x="250" y="165" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">Learn patterns</text>
  
  <!-- Arrow to Inference -->
  <line x1="310" y1="140" x2="360" y2="140" stroke="#7f8c8d" stroke-width="3" marker-end="url(#arrow)"/>
  
  <!-- Trained Model -->
  <rect x="370" y="90" width="100" height="100" rx="10" fill="#27ae60"/>
  <text x="420" y="125" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="white">Trained</text>
  <text x="420" y="145" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="white">Model</text>
  <text x="420" y="165" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">(Inference)</text>
  
  <!-- New Data -->
  <rect x="370" y="220" width="100" height="60" rx="10" fill="#e74c3c"/>
  <text x="420" y="255" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="white">New Data</text>
  
  <!-- Arrow up -->
  <line x1="420" y1="220" x2="420" y2="200" stroke="#7f8c8d" stroke-width="3" marker-end="url(#arrow)"/>
  
  <!-- Predictions -->
  <rect x="200" y="250" width="120" height="60" rx="10" fill="#f39c12"/>
  <text x="260" y="275" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="white">Predictions</text>
  <text x="260" y="295" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">(Output)</text>
  
  <!-- Arrow from model to predictions -->
  <path d="M 370 140 Q 320 140 320 200 Q 320 280 320 280" stroke="#7f8c8d" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  
  <!-- Labels -->
  <text x="80" y="200" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#7f8c8d">Input</text>
  <text x="250" y="210" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#7f8c8d">Process</text>
  <text x="420" y="180" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#7f8c8d">Apply</text>
</svg>