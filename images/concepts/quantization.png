<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
  <!-- Background -->
  <rect width="600" height="400" fill="#f8f9fa"/>
  
  <!-- Title -->
  <text x="300" y="30" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle" fill="#2c3e50">Quantization: Reducing Model Precision</text>
  
  <!-- FP32 (Full Precision) -->
  <rect x="30" y="70" width="170" height="140" rx="10" fill="#e74c3c" stroke="#c0392b" stroke-width="2"/>
  <text x="115" y="100" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">FP32</text>
  <text x="115" y="120" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">(Full Precision)</text>
  
  <!-- 32-bit representation -->
  <rect x="50" y="140" width="130" height="20" rx="3" fill="#2c3e50"/>
  <rect x="50" y="140" width="30" height="20" fill="#3498db"/>
  <text x="65" y="155" font-family="Arial, sans-serif" font-size="8" text-anchor="middle" fill="white">S</text>
  <rect x="80" y="140" width="40" height="20" fill="#27ae60"/>
  <text x="100" y="155" font-family="Arial, sans-serif" font-size="8" text-anchor="middle" fill="white">Exp</text>
  <rect x="120" y="140" width="60" height="20" fill="#f39c12"/>
  <text x="150" y="155" font-family="Arial, sans-serif" font-size="8" text-anchor="middle" fill="white">Mantissa</text>
  
  <text x="115" y="180" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">32 bits = 4 bytes</text>
  <text x="115" y="200" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">Max precision</text>
  
  <!-- Arrow -->
  <text x="230" y="150" font-family="Arial, sans-serif" font-size="20" fill="#7f8c8d">→</text>
  <text x="230" y="170" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#7f8c8d">Compress</text>
  
  <!-- INT8 (8-bit Quantization) -->
  <rect x="260" y="70" width="170" height="140" rx="10" fill="#f39c12" stroke="#d68910" stroke-width="2"/>
  <text x="345" y="100" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">INT8</text>
  <text x="345" y="120" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">(8-bit Quantized)</text>
  
  <!-- 8-bit representation -->
  <rect x="280" y="140" width="130" height="20" rx="3" fill="#2c3e50"/>
  <rect x="280" y="140" width="130" height="20" fill="#27ae60"/>
  <text x="345" y="155" font-family="Arial, sans-serif" font-size="8" text-anchor="middle" fill="white">8 bits = 1 byte</text>
  
  <text x="345" y="180" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">8 bits = 1 byte</text>
  <text x="345" y="200" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">4x smaller</text>
  
  <!-- Arrow -->
  <text x="460" y="150" font-family="Arial, sans-serif" font-size="20" fill="#7f8c8d">→</text>
  <text x="460" y="170" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#7f8c8d">Compress</text>
  
  <!-- INT4 (4-bit Quantization) -->
  <rect x="490" y="70" width="90" height="140" rx="10" fill="#27ae60" stroke="#1e8449" stroke-width="2"/>
  <text x="535" y="100" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">INT4</text>
  <text x="535" y="120" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">(4-bit)</text>
  
  <!-- 4-bit representation -->
  <rect x="505" y="140" width="60" height="20" rx="3" fill="#2c3e50"/>
  <rect x="505" y="140" width="60" height="20" fill="#3498db"/>
  <text x="535" y="155" font-family="Arial, sans-serif" font-size="8" text-anchor="middle" fill="white">4 bits</text>
  
  <text x="535" y="180" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">4 bits</text>
  <text x="535" y="200" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="white">8x smaller</text>
  
  <!-- Memory Comparison -->
  <rect x="30" y="230" width="540" height="80" rx="8" fill="white" stroke="#ddd" stroke-width="1"/>
  <text x="300" y="255" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="#2c3e50">Memory Comparison for 7B Model</text>
  
  <rect x="50" y="270" width="200" height="25" fill="#e74c3c"/>
  <text x="150" y="288" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">FP32: ~28 GB</text>
  
  <rect x="270" y="270" width="100" height="25" fill="#f39c12"/>
  <text x="320" y="288" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">INT8: ~8 GB</text>
  
  <rect x="390" y="270" width="50" height="25" fill="#27ae60"/>
  <text x="415" y="288" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="white">INT4: ~4 GB</text>
  
  <!-- Tradeoff Note -->
  <rect x="30" y="330" width="540" height="50" rx="8" fill="#fff3cd" stroke="#ffc107" stroke-width="1"/>
  <text x="300" y="350" font-family="Arial, sans-serif" font-size="10" font-weight="bold" text-anchor="middle" fill="#856404">Tradeoff: Lower precision = Less memory but slightly reduced accuracy</text>
  <text x="300" y="365" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#856404">Impact varies by task - often acceptable for inference</text>
</svg>